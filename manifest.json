{
  "manifest_version": 3,
  "name": "Threadsmith",
  "description": "Shape messy ChatGPT history into clear, searchable titles.",
  "version": "0.2.0",
  "permissions": ["activeTab", "storage", "tabs"],
  "host_permissions": ["https://chatgpt.com/*", "https://chat.openai.com/*", "https://api.deepseek.com/*"],
  "action": {
    "default_title": "Threadsmith",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "service_worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ]
}
